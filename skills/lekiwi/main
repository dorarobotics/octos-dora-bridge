#!/usr/bin/env python3
"""octos app-skill `main` — LeKiwi mobile-base tools over the SPEC bridge.

octos spawns this per tool call as `main <tool_name>` with the tool args as JSON on
stdin, and expects a single JSON object on stdout: {"output": <str>, "success": <bool>}.

Each tool maps to existing SPEC verbs on the nav-base bridge (HTTP, :8770):
  move_base      -> base.set_velocity, wait `seconds`, then base.stop
  stop_base      -> base.stop
  get_base_pose  -> localization.get_pose
move_base bounds the motion client-side (set_velocity + stop) so a single tool call
is a complete, self-terminating action; it adds no new robot capability.

Env: LEKIWI_BRIDGE_URL (default http://127.0.0.1:8770).
"""
import json
import os
import sys
import time
import urllib.request

BRIDGE = os.environ.get("LEKIWI_BRIDGE_URL", "http://127.0.0.1:8770")
MAX_SECONDS = 10.0


def _emit(output, success):
    print(json.dumps({"output": str(output), "success": bool(success)}))
    sys.exit(0)


def _post(verb, **args):
    body = json.dumps({"args": args}).encode()
    req = urllib.request.Request(
        f"{BRIDGE}/tools/{verb}",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=5) as resp:
        return json.loads(resp.read().decode())


def _pose_str():
    r = _post("vendor.dora_nav.localization.get_pose")
    return (r.get("data") or {}).get("pose")


def main():
    tool = sys.argv[1] if len(sys.argv) > 1 else ""
    raw = sys.stdin.read() if not sys.stdin.isatty() else ""
    try:
        args = json.loads(raw) if raw.strip() else {}
    except json.JSONDecodeError:
        _emit(f"invalid JSON args on stdin for '{tool}'", False)

    try:
        if tool == "move_base":
            linear = float(args.get("linear", 0.0))
            angular = float(args.get("angular", 0.0))
            seconds = max(0.0, min(float(args.get("seconds", 2.0)), MAX_SECONDS))
            r = _post("vendor.dora_nav.base.set_velocity",
                      linear=linear, angular=angular, control_source="octos")
            if not r.get("ok"):
                _emit(f"set_velocity failed: code={r.get('code')} msg={r.get('msg')}", False)
            time.sleep(seconds)
            try:
                _post("vendor.dora_nav.base.stop")
            except Exception as exc:  # noqa: BLE001
                _emit(f"WARNING: moved for {seconds}s but the stop call failed ({exc}); "
                      f"the base may STILL BE MOVING — call stop_base now (bridge {BRIDGE})", False)
            _emit(f"moved (linear={linear} m/s, angular={angular} rad/s) for {seconds}s, "
                  f"then stopped. pose now: {_pose_str()}", True)
        elif tool == "stop_base":
            r = _post("vendor.dora_nav.base.stop")
            _emit(f"stopped. ok={r.get('ok')}", bool(r.get("ok")))
        elif tool == "get_base_pose":
            _emit(f"pose: {_pose_str()}", True)
        else:
            _emit(f"unknown tool '{tool}'", False)
    except Exception as exc:  # noqa: BLE001
        _emit(f"bridge call failed ({type(exc).__name__}: {exc}); is the dataflow up on {BRIDGE}?", False)


if __name__ == "__main__":
    main()
